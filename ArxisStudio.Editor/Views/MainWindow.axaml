<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArxisStudio.Editor.ViewModels"
        xmlns:m="using:ArxisStudio.Editor.Models"
        xmlns:lm="using:ArxisStudio.Markup.Json.Loader.Models"
        xmlns:designer="using:ArxisStudio.Designer.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:j="using:Newtonsoft.Json.Linq"
        mc:Ignorable="d"
        d:DesignWidth="1580"
        d:DesignHeight="920"
        x:Class="ArxisStudio.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ArxisStudio Editor"
        MinHeight="720"
        MinWidth="1280"
        Background="#1F2125">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush">#1F2125</SolidColorBrush>
        <SolidColorBrush x:Key="ChromeBrush">#2A2D31</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBrush">#25282C</SolidColorBrush>
        <SolidColorBrush x:Key="PanelRaisedBrush">#2B2E33</SolidColorBrush>
        <SolidColorBrush x:Key="EditorBrush">#1E1F22</SolidColorBrush>
        <SolidColorBrush x:Key="EditorAltBrush">#23252A</SolidColorBrush>
        <SolidColorBrush x:Key="CanvasBrush">#111214</SolidColorBrush>
        <SolidColorBrush x:Key="CanvasGridBrush">#26364A</SolidColorBrush>
        <SolidColorBrush x:Key="StrokeBrush">#3B3F45</SolidColorBrush>
        <SolidColorBrush x:Key="StrokeStrongBrush">#4A596A</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBrush">#4EA1F3</SolidColorBrush>
        <SolidColorBrush x:Key="AccentSoftBrush">#203246</SolidColorBrush>
        <SolidColorBrush x:Key="SuccessBrush">#61D095</SolidColorBrush>
        <SolidColorBrush x:Key="DangerBrush">#E06C75</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimaryBrush">#D7DAE0</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondaryBrush">#9CA3AF</SolidColorBrush>
        <SolidColorBrush x:Key="TextMutedBrush">#6F7782</SolidColorBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.panel.raised">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.helper">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.kicker">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.chrome">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinWidth" Value="30" />
        </Style>

        <Style Selector="Button.sidebar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.mode-tab">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="12,7" />
        </Style>

        <Style Selector="Border.mode-tab.active">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>

        <Style Selector="TextBlock.mode-tab">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Border.mode-tab.active TextBlock.mode-tab">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBox.editor">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style Selector="ListBox.ide-list">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style Selector="TreeView.ide-tree">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style Selector="TreeView.ide-tree TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="36, *, 160">
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"
                           Text="RD"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#F26D6D"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Grid.Column="1" Classes="chrome" Content="☰" />
                <Button Grid.Column="2" Classes="chrome" Content="←" />
                <Button Grid.Column="3" Classes="chrome" Content="→" />

                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="ArxisStudio.Editor"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <Button Classes="chrome"
                            Content="▶"
                            Command="{Binding RunProjectCommand}"
                            IsEnabled="{Binding CanRunProject}" />
                    <Button Classes="chrome"
                            Content="■"
                            Command="{Binding StopProjectCommand}"
                            IsEnabled="{Binding CanStopProject}" />
                </StackPanel>

                <Button Grid.Column="6" Classes="chrome" Content="⚙" />
                <Button Grid.Column="7" Classes="chrome" Content="⋮" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="44, 380, 10, *, 320">
            <Border Grid.Column="0"
                    Background="{StaticResource EditorBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Spacing="6" Margin="0,10,0,10">
                    <Button Classes="sidebar" Content="≡" />
                    <Button Classes="sidebar" Content="⊙" />
                    <Button Classes="sidebar" Content="◧" />
                    <Button Classes="sidebar" Content="⋯" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource EditorAltBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="34, *, 220">
                    <Border Grid.Row="0"
                            Background="{StaticResource ChromeBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Solution"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProjectSummary}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="180" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Margin="10">
                        <TextBox Grid.Row="0"
                                 Classes="editor"
                                 Text="{Binding ProjectPathInput, Mode=TwoWay}"
                                 Watermark="Path to .csproj or .sln"
                                 VerticalContentAlignment="Center" />

                        <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,10,0,10">
                            <Button Grid.Column="0"
                                    Content="Load Project"
                                    Command="{Binding LoadProjectCommand}" />
                            <Button Grid.Column="2"
                                    Content="Open Selected"
                                    Command="{Binding OpenSelectedProjectFileCommand}" />
                        </Grid>

                        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
                            <TextBlock Text=".arxui Files"
                                       Classes="section-title" />
                            <ListBox Grid.Row="1"
                                     Classes="ide-list"
                                     ItemsSource="{Binding ProjectArxuiFiles}"
                                     SelectedItem="{Binding SelectedProjectFile, Mode=TwoWay}"
                                     DoubleTapped="ProjectFilesListBox_DoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="lm:ProjectFileItem">
                                        <StackPanel Margin="4,3">
                                            <TextBlock Text="{Binding RelativePath}"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Kind}"
                                                       Classes="helper" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <TextBlock Text="Toolbox"
                                       Classes="section-title" />
                            <ListBox Grid.Row="1"
                                     Classes="ide-list"
                                     ItemsSource="{Binding AvailableControls}"
                                     SelectionMode="Single"
                                     SelectionChanged="ToolboxListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:ToolboxItem">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Margin="4"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   ToolTip.Tip="Select to add to the chosen container" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="2"
                          Background="{StaticResource StrokeBrush}"
                          ResizeDirection="Columns"
                          Width="10" />

            <Grid Grid.Column="3" RowDefinitions="36,*">
                <Border Grid.Row="0"
                        Background="{StaticResource ChromeBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,16,Auto,*" Margin="8,0">
                        <Button Grid.Column="0"
                                Classes="chrome"
                                Content="Designer"
                                Command="{Binding SetWorkspaceModeCommand}"
                                CommandParameter="Designer" />
                        <Button Grid.Column="1"
                                Classes="chrome"
                                Content="Source"
                                Command="{Binding SetWorkspaceModeCommand}"
                                CommandParameter="Source" />
                        <Button Grid.Column="2"
                                Classes="chrome"
                                Content="Split"
                                Command="{Binding SetWorkspaceModeCommand}"
                                CommandParameter="Split" />
                        <Border Grid.Column="4"
                                Classes="mode-tab"
                                Padding="10,7"
                                Margin="0">
                            <TextBlock Classes="mode-tab" Text="MainWindow.arxui" />
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid IsVisible="{Binding IsDesignerMode}" ColumnDefinitions="280, *, 18">
                        <Border Grid.Column="0"
                                Classes="panel"
                                BorderThickness="0,0,1,1">
                            <Grid RowDefinitions="36,*">
                                <Border Grid.Row="0"
                                        Background="{StaticResource ChromeBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,0">
                                    <TextBlock Text="Document Outline"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>

                                <TreeView Grid.Row="1"
                                          Classes="ide-tree"
                                          Margin="8"
                                          ItemsSource="{Binding ControlTreeRoot.Children}"
                                          SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                                    <TreeView.DataTemplates>
                                        <TreeDataTemplate x:DataType="m:ControlNode"
                                                          ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Margin="4,2"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </TreeDataTemplate>
                                    </TreeView.DataTemplates>
                                </TreeView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource CanvasBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid RowDefinitions="38, *, 38">
                                <Border Grid.Row="0"
                                        Background="{StaticResource ChromeBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,0">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                                        <TextBlock Text="ArxisStudio.Markup.Template"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Classes="chrome" Content="−" Command="{Binding ZoomOutCommand}" />
                                        <Button Grid.Column="3" Classes="chrome" Content="↺" Command="{Binding ResetZoomCommand}" />
                                        <Button Grid.Column="4" Classes="chrome" Content="+" Command="{Binding ZoomInCommand}" />
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding PreviewZoomPercent}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0"
                                        Background="{StaticResource CanvasBrush}">
                                    <Grid ShowGridLines="False">
                                        <Canvas>
                                            <Rectangle Width="2000"
                                                       Height="2000"
                                                       Fill="Transparent"
                                                       Stroke="{StaticResource CanvasGridBrush}"
                                                       StrokeThickness="0.25"
                                                       StrokeDashArray="1,11" />
                                        </Canvas>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Grid Margin="90">
                                                <Border Background="#000000"
                                                        BorderBrush="{StaticResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        Padding="40"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        RenderTransformOrigin="0,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}" />
                                                    </Border.RenderTransform>
                                                    <designer:DesignerSurfaceControl Document="{Binding CurrentDocument}"
                                                                                     Zoom="{Binding PreviewZoom}"
                                                                                     PreviewBuilder="{Binding DesignerPreviewBuilder}"
                                                                                     SelectionService="{Binding DesignerSelectionService}" />
                                                </Border>
                                            </Grid>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Background="{StaticResource ChromeBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="12,0">
                                    <TextBlock Text="Preview builds the UI from .arxui and project resources without running user event code."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource EditorBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1,0,0,1">
                            <TextBlock Text="⋮"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,10,0,0" />
                        </Border>
                    </Grid>

                    <Border IsVisible="{Binding IsSourceMode}"
                            Background="{StaticResource EditorBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid RowDefinitions="34,*">
                            <Border Grid.Row="0"
                                    Background="{StaticResource ChromeBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,0">
                                <TextBlock Text="Source"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </Border>

                            <TextBox Grid.Row="1"
                                     Classes="editor"
                                     Margin="10"
                                     Text="{Binding JsonText}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                                     FontSize="12.5"
                                     TextWrapping="NoWrap" />
                        </Grid>
                    </Border>

                    <Grid IsVisible="{Binding IsSplitMode}" RowDefinitions="*,240">
                        <Grid Grid.Row="0" ColumnDefinitions="280, *, 18">
                            <Border Grid.Column="0"
                                    Classes="panel"
                                    BorderThickness="0,0,1,1">
                                <Grid RowDefinitions="36,*">
                                    <Border Grid.Row="0"
                                            Background="{StaticResource ChromeBrush}"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,0">
                                        <TextBlock Text="Document Outline"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <TreeView Grid.Row="1"
                                              Classes="ide-tree"
                                              Margin="8"
                                              ItemsSource="{Binding ControlTreeRoot.Children}"
                                              SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                                        <TreeView.DataTemplates>
                                            <TreeDataTemplate x:DataType="m:ControlNode"
                                                              ItemsSource="{Binding Children}">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Margin="4,2"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </TreeDataTemplate>
                                        </TreeView.DataTemplates>
                                    </TreeView>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="{StaticResource CanvasBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid RowDefinitions="38, *, 38">
                                    <Border Grid.Row="0"
                                            Background="{StaticResource ChromeBrush}"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="ArxisStudio.Markup.Template"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Classes="chrome" Content="−" Command="{Binding ZoomOutCommand}" />
                                            <Button Grid.Column="3" Classes="chrome" Content="↺" Command="{Binding ResetZoomCommand}" />
                                            <Button Grid.Column="4" Classes="chrome" Content="+" Command="{Binding ZoomInCommand}" />
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding PreviewZoomPercent}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Margin="0"
                                            Background="{StaticResource CanvasBrush}">
                                        <Grid ShowGridLines="False">
                                            <Canvas>
                                                <Rectangle Width="2000"
                                                           Height="2000"
                                                           Fill="Transparent"
                                                           Stroke="{StaticResource CanvasGridBrush}"
                                                           StrokeThickness="0.25"
                                                           StrokeDashArray="1,11" />
                                            </Canvas>
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <Grid Margin="90">
                                                    <Border Background="#000000"
                                                            BorderBrush="{StaticResource StrokeBrush}"
                                                            BorderThickness="1"
                                                            Padding="40"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            RenderTransformOrigin="0,0">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}" />
                                                        </Border.RenderTransform>
                                                        <designer:DesignerSurfaceControl Document="{Binding CurrentDocument}"
                                                                                         Zoom="{Binding PreviewZoom}"
                                                                                         PreviewBuilder="{Binding DesignerPreviewBuilder}"
                                                                                         SelectionService="{Binding DesignerSelectionService}" />
                                                    </Border>
                                                </Grid>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="{StaticResource ChromeBrush}"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="12,0">
                                        <TextBlock Text="Preview builds the UI from .arxui and project resources without running user event code."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="{StaticResource EditorBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1,0,0,1">
                                <TextBlock Text="⋮"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,10,0,0" />
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource EditorBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid RowDefinitions="34,*">
                                <Border Grid.Row="0"
                                        Background="{StaticResource ChromeBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,0">
                                    <TextBlock Text="Source"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </Border>

                                <TextBox Grid.Row="1"
                                         Classes="editor"
                                         Margin="10"
                                         Text="{Binding JsonText}"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                                         FontSize="12.5"
                                         TextWrapping="NoWrap" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Column="4"
                    Background="{StaticResource EditorAltBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="36, *, 128, 48">
                    <Border Grid.Row="0"
                            Background="{StaticResource ChromeBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,0">
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <TextBlock Text="Inspector"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="Properties"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="8" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EditableProperties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:PropertyItem">
                                    <Border Margin="0,0,0,10"
                                            Padding="8"
                                            Background="{StaticResource PanelBrush}"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="1">
                                        <Grid RowDefinitions="Auto, Auto" RowSpacing="6">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBox Grid.Row="1"
                                                     Classes="editor"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Watermark="{Binding Name}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,1,0,1"
                            Padding="8">
                        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                            <TextBlock Text="Diagnostics"
                                       Classes="section-title" />
                            <TextBlock Grid.Row="1"
                                       Text="Last message"
                                       Classes="kicker" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding ErrorMessage}"
                                       Foreground="#F0B5BD"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="3"
                            Margin="8"
                            Content="Delete Selected Control"
                            Command="{Binding DeleteSelectedControlCommand}" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource EditorBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,1,0,0">
            <Grid RowDefinitions="34,*">
                <Border Grid.Row="0"
                        Background="{StaticResource ChromeBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,0">
                    <Grid ColumnDefinitions="Auto,16,Auto,8,Auto,16,*">
                        <TextBlock Text="Run"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                        <Button Grid.Column="2"
                                Content="Start"
                                Command="{Binding RunProjectCommand}"
                                IsEnabled="{Binding CanRunProject}"
                                VerticalAlignment="Center" />
                        <Button Grid.Column="4"
                                Content="Stop"
                                Command="{Binding StopProjectCommand}"
                                IsEnabled="{Binding CanStopProject}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6"
                                   Text="{Binding RunStatus}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         Classes="editor"
                         Margin="12"
                         Text="{Binding RunOutput}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                         FontSize="12.5" />
            </Grid>
        </Border>
    </Grid>
</Window>
