<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArxisStudio.Editor.ViewModels"
        xmlns:m="using:ArxisStudio.Editor.Models"
        xmlns:designer="using:ArxisStudio.Designer"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1600"
        d:DesignHeight="930"
        x:Class="ArxisStudio.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ArxisStudio Editor [DesignEditor V2]"
        Icon="/Assets/avalonia-logo.ico"
        MinWidth="1300"
        MinHeight="760"
        Background="#1F2125">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush">#1F2125</SolidColorBrush>
        <SolidColorBrush x:Key="ChromeBrush">#2A2D31</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBrush">#25282C</SolidColorBrush>
        <SolidColorBrush x:Key="PanelRaisedBrush">#2B2E33</SolidColorBrush>
        <SolidColorBrush x:Key="EditorBrush">#1E1F22</SolidColorBrush>
        <SolidColorBrush x:Key="EditorAltBrush">#23252A</SolidColorBrush>
        <SolidColorBrush x:Key="CanvasBrush">#111214</SolidColorBrush>
        <SolidColorBrush x:Key="CanvasGridBrush">#26364A</SolidColorBrush>
        <SolidColorBrush x:Key="StrokeBrush">#3B3F45</SolidColorBrush>
        <SolidColorBrush x:Key="StrokeStrongBrush">#4A596A</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBrush">#4EA1F3</SolidColorBrush>
        <SolidColorBrush x:Key="SuccessBrush">#61D095</SolidColorBrush>
        <SolidColorBrush x:Key="DangerBrush">#E06C75</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimaryBrush">#D7DAE0</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondaryBrush">#9CA3AF</SolidColorBrush>
        <SolidColorBrush x:Key="TextMutedBrush">#6F7782</SolidColorBrush>
        <SolidColorBrush x:Key="TreeItemHoverBrush">#31353B</SolidColorBrush>
        <SolidColorBrush x:Key="TreeItemSelectedBrush">#3A4452</SolidColorBrush>

        <SolidColorBrush x:Key="DesignerGridBackgroundBrush">#0F131A</SolidColorBrush>
        <SolidColorBrush x:Key="DesignerGridSmallLineBrush">#1F2A3A</SolidColorBrush>
        <SolidColorBrush x:Key="DesignerGridLargeLineBrush">#2E3D55</SolidColorBrush>

        <DrawingGroup x:Key="DesignerUnifiedGridDrawing">
            <GeometryDrawing Brush="{StaticResource DesignerGridBackgroundBrush}">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,100,100" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="{x:Null}">
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource DesignerGridSmallLineBrush}" Thickness="1" />
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <GeometryGroup>
                        <LineGeometry StartPoint="20,0" EndPoint="20,100" />
                        <LineGeometry StartPoint="40,0" EndPoint="40,100" />
                        <LineGeometry StartPoint="60,0" EndPoint="60,100" />
                        <LineGeometry StartPoint="80,0" EndPoint="80,100" />
                        <LineGeometry StartPoint="0,20" EndPoint="100,20" />
                        <LineGeometry StartPoint="0,40" EndPoint="100,40" />
                        <LineGeometry StartPoint="0,60" EndPoint="100,60" />
                        <LineGeometry StartPoint="0,80" EndPoint="100,80" />
                    </GeometryGroup>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="{x:Null}">
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource DesignerGridLargeLineBrush}" Thickness="1" />
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <StreamGeometry>M0,0 L100,0 M0,0 L0,100</StreamGeometry>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingGroup>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.subtle">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>

        <Style Selector="TextBlock.panelCaption">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBox.ide">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="7,5" />
        </Style>

        <Style Selector="ListBox.ide">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style Selector="ListBox.tabs">
            <Setter Property="Background" Value="{StaticResource ChromeBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.tabs ListBoxItem">
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style Selector="ListBox.tabs ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBox.tabs ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style Selector="TreeView.ide">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style Selector="TreeView.ide TreeViewItem">
            <Setter Property="Padding" Value="2,2,2,2" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TreeView.ide TreeViewItem:pointerover /template/ Border#Selection">
            <Setter Property="Background" Value="{StaticResource TreeItemHoverBrush}" />
        </Style>

        <Style Selector="TreeView.ide TreeViewItem:selected /template/ Border#Selection">
            <Setter Property="Background" Value="{StaticResource TreeItemSelectedBrush}" />
        </Style>

        <Style Selector="Border.section">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.tab">
            <Setter Property="Background" Value="{StaticResource EditorBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style Selector="Button.idePrimary">
            <Setter Property="Background" Value="#3F6FA3" />
            <Setter Property="BorderBrush" Value="#4E83BC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F1F5FA" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style Selector="Button.ideGhost">
            <Setter Property="Background" Value="{StaticResource EditorAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style Selector="Border.treeBadge">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Background" Value="{StaticResource EditorAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.topbar">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="30,34,34,*,170,24">
        <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Project" Classes="subtle" />
                <TextBlock Text="Run" Classes="subtle" />
                <TextBlock Text="Help" Classes="subtle" />
                <TextBlock Text="Language" Classes="subtle" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource PanelRaisedBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,12,Auto,Auto,Auto,*,Auto" Margin="10,2,10,2" VerticalAlignment="Center">
                <Button Grid.Column="0" Content="Open" Width="50" Classes="ideGhost topbar" />
                <Button Grid.Column="1" Content="Save" Width="50" Margin="6,0,0,0" Classes="ideGhost topbar" />
                <Button Grid.Column="2" Content="Build" Width="54" Margin="6,0,0,0" Classes="ideGhost topbar" />
                <Button Grid.Column="4" Content="Start" Command="{Binding RunProjectCommand}" IsEnabled="{Binding CanRunProject}" Classes="idePrimary topbar" />
                <Button Grid.Column="5" Content="Stop" Command="{Binding StopProjectCommand}" IsEnabled="{Binding CanStopProject}" Margin="6,0,0,0" Classes="ideGhost topbar" />
                <TextBlock Grid.Column="6" Text="{Binding RunStatus}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBox Grid.Column="8" Classes="ide" Width="220" Watermark="Search..." />
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1">
            <ListBox Margin="10,0"
                     Classes="tabs"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalAlignment="Stretch"
                     SelectionMode="Single"
                     ItemsSource="{Binding OpenDocumentTabs}"
                     SelectedItem="{Binding SelectedOpenDocumentTab, Mode=TwoWay}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:OpenDocumentTab">
                        <Border Padding="10,4,6,4">
                            <Grid ColumnDefinitions="*,6,Auto">
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="x"
                                        Width="18"
                                        Height="18"
                                        Padding="0"
                                        Click="CloseTabButton_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="340,6,*,6,330">
            <Grid Grid.Column="0" RowDefinitions="*,6,*" Margin="8,8,0,8">
                <Border Grid.Row="0" Classes="section">
                    <Grid RowDefinitions="32,Auto,*">
                        <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="10,0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Project" Classes="header" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Solution Explorer" Classes="subtle" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,8,Auto,12,*" Margin="8,8,8,8">
                            <Button Grid.Column="0" Content="Open Project" MinWidth="110" Click="OpenProjectButton_Click" Classes="idePrimary" />
                            <Button Grid.Column="2" Content="Open Selected" MinWidth="110" Command="{Binding OpenSelectedProjectFileCommand}" Classes="ideGhost" />
                            <TextBlock Grid.Column="4" Text="{Binding ProjectSummary}" Classes="subtle" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TreeView Grid.Row="2"
                                  Margin="8,0,8,8"
                                  Classes="ide"
                                  ItemsSource="{Binding ProjectTreeItems}"
                                  SelectedItem="{Binding SelectedProjectTreeItem, Mode=TwoWay}"
                                  DoubleTapped="ProjectTreeView_DoubleTapped">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate x:DataType="m:ProjectTreeItem" ItemsSource="{Binding Children}">
                                    <Grid ColumnDefinitions="Auto,8,*,8,Auto" Margin="0,1">
                                        <Border Classes="treeBadge" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Badge}" Classes="subtle" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding KindLabel}" Classes="subtle" VerticalAlignment="Center" Opacity="0.75" />
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open" Click="ProjectTreeOpenMenuItem_Click" />
                                                <MenuItem Header="Reveal in Explorer" Click="ProjectTreeRevealMenuItem_Click" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="6" Background="{StaticResource StrokeBrush}" ResizeDirection="Rows" />

                <Border Grid.Row="2" Classes="section">
                    <Grid RowDefinitions="32,*">
                        <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="10,0">
                            <TextBlock Text="Document Outline" Classes="header" VerticalAlignment="Center" />
                        </Border>
                        <TreeView Grid.Row="1"
                                  Margin="8"
                                  Classes="ide"
                                  ItemsSource="{Binding ControlTreeRoot.Children}"
                                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate x:DataType="m:ControlNode" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" />
                                </TreeDataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Background="{StaticResource StrokeBrush}" Width="6" ResizeDirection="Columns" />

            <Grid Grid.Column="2" RowDefinitions="32,32,*" Margin="8,8,8,8">
                <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                        <Button Classes="tab" Content="Designer" Command="{Binding SetWorkspaceModeCommand}" CommandParameter="Designer" />
                        <Button Classes="tab" Content="Source" Command="{Binding SetWorkspaceModeCommand}" CommandParameter="Source" />
                        <Button Classes="tab" Content="Split" Command="{Binding SetWorkspaceModeCommand}" CommandParameter="Split" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource PanelRaisedBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1,1,1,0" Padding="8,0">
                    <Grid ColumnDefinitions="Auto,8,Auto,8,Auto,*,Auto,6,Auto">
                        <TextBlock Text="Design" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Grid.Column="2" Content="-" Command="{Binding ZoomOutCommand}" Width="24" Height="24" />
                        <Button Grid.Column="4" Content="+" Command="{Binding ZoomInCommand}" Width="24" Height="24" />
                        <TextBlock Grid.Column="6" Text="{Binding PreviewZoomPercent}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Grid.Column="8" Content="100%" Command="{Binding ResetZoomCommand}" Height="24" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                    <Grid>
                        <Grid IsVisible="{Binding IsDesignerMode}">
                            <designer:DesignEditor x:Name="DesignerEditor"
                                                   Margin="10"
                                                   BorderBrush="{StaticResource StrokeStrongBrush}"
                                                   BorderThickness="1"
                                                   ItemsSource="{Binding DesignerItems}"
                                                   SelectionMode="Single"
                                                   ViewportZoom="{Binding PreviewZoom, Mode=TwoWay}"
                                                   MinZoom="0.25"
                                                   MaxZoom="3">
                                <designer:DesignEditor.Background>
                                    <DrawingBrush TileMode="Tile"
                                                  DestinationRect="0 0 100 100"
                                                  Transform="{Binding DpiScaledViewportTransform, ElementName=DesignerEditor}"
                                                  Drawing="{StaticResource DesignerUnifiedGridDrawing}" />
                                </designer:DesignEditor.Background>
                            </designer:DesignEditor>
                        </Grid>

                        <TextBox IsVisible="{Binding IsSourceMode}"
                                 Classes="ide"
                                 Margin="10"
                                 Text="{Binding JsonText}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                                 FontSize="12.5" />

                        <Grid IsVisible="{Binding IsSplitMode}" RowDefinitions="*,6,*">
                            <Grid Grid.Row="0">
                                <designer:DesignEditor x:Name="SplitDesignerEditor"
                                                       Margin="10"
                                                       BorderBrush="{StaticResource StrokeStrongBrush}"
                                                       BorderThickness="1"
                                                       ItemsSource="{Binding SplitDesignerItems}"
                                                       SelectionMode="Single"
                                                       ViewportZoom="{Binding PreviewZoom, Mode=TwoWay}"
                                                       MinZoom="0.25"
                                                       MaxZoom="3">
                                    <designer:DesignEditor.Background>
                                        <DrawingBrush TileMode="Tile"
                                                      DestinationRect="0 0 100 100"
                                                      Transform="{Binding DpiScaledViewportTransform, ElementName=SplitDesignerEditor}"
                                                      Drawing="{StaticResource DesignerUnifiedGridDrawing}" />
                                    </designer:DesignEditor.Background>
                                </designer:DesignEditor>
                            </Grid>
                            <GridSplitter Grid.Row="1" Height="6" Background="{StaticResource StrokeBrush}" ResizeDirection="Rows" />
                            <TextBox Grid.Row="2"
                                     Classes="ide"
                                     Margin="10"
                                     Text="{Binding JsonText}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                                     FontSize="12.5" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Background="{StaticResource StrokeBrush}" Width="6" ResizeDirection="Columns" />

            <Grid Grid.Column="4" RowDefinitions="32,*,32,*,110,42" Margin="0,8,8,8">
                <Border Grid.Row="0" Classes="section" BorderThickness="1,1,1,0" Background="{StaticResource ChromeBrush}" Padding="10,0">
                    <Grid ColumnDefinitions="Auto,10,Auto,*">
                        <TextBlock Text="Objects" Classes="header" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Properties" Classes="subtle" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="section">
                    <Grid RowDefinitions="30,*">
                        <Border Grid.Row="0" Background="{StaticResource PanelRaisedBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="8,0">
                            <TextBox Classes="ide" Watermark="Search controls" />
                        </Border>
                        <ListBox Grid.Row="1"
                                 Margin="8"
                                 Classes="ide"
                                 ItemsSource="{Binding AvailableControls}"
                                 SelectionMode="Single"
                                 SelectionChanged="ToolboxListBox_SelectionChanged"
                                 PointerPressed="ToolboxListBox_PointerPressed"
                                 PointerMoved="ToolboxListBox_PointerMoved"
                                 DoubleTapped="ToolboxListBox_DoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:ToolboxItem">
                                    <Border Margin="0,0,0,4" Padding="6,4" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Classes="section" BorderThickness="1,1,1,0" Background="{StaticResource ChromeBrush}" Padding="10,0">
                    <TextBlock Text="Inspector" Classes="header" VerticalAlignment="Center" />
                </Border>

                <Border Grid.Row="3" Classes="section">
                    <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EditableProperties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:PropertyItem">
                                    <Border Margin="0,0,0,8" Padding="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                            <TextBox Grid.Row="1" Classes="ide" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="4" Classes="section" BorderThickness="1,1,1,0" Padding="8">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Text="Diagnostics" Classes="header" />
                        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="2" Text="Last message" Classes="subtle" VerticalAlignment="Bottom" />
                    </Grid>
                </Border>

                <Button Grid.Row="5"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Content="Delete Selected Control"
                        Command="{Binding DeleteSelectedControlCommand}" />
            </Grid>
        </Grid>

        <Border Grid.Row="4" Background="{StaticResource EditorBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,1">
            <Grid RowDefinitions="30,*">
                <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="10,0">
                    <Grid ColumnDefinitions="Auto,8,Auto,8,*">
                        <Button Content="Start" Command="{Binding RunProjectCommand}" IsEnabled="{Binding CanRunProject}" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="Stop" Command="{Binding StopProjectCommand}" IsEnabled="{Binding CanStopProject}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding RunStatus}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                </Border>
                <TextBox Grid.Row="1"
                         Margin="10"
                         Classes="ide"
                         Text="{Binding RunOutput}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas, Cascadia Code, Menlo, Monaco"
                         FontSize="12.5" />
            </Grid>
        </Border>

        <Border Grid.Row="5" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="10,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding ProjectSummary}" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                <TextBlock Grid.Column="1" Text="ArxisStudio.Markup.Template" VerticalAlignment="Center" Foreground="{StaticResource SuccessBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
