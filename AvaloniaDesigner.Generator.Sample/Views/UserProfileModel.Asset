{
  "FormName": "UserProfile",
  "NamespaceSuffix": "Views",
  "ParentClassType": "Avalonia.Controls.UserControl",
  "Properties": {
    "Content": {
      "Type": "Avalonia.Controls.Grid",
      "Properties": {
        "Name": "RootGrid",
        "RowDefinitions": "Auto, *, Auto",
        "Margin": "0",
        "Background": { "$resource": "BackgroundBrush" },

        "Children": [
          {
            "Type": "Avalonia.Controls.Border",
            "Properties": {
              "Avalonia.Controls.Grid.Row": 0,
              "Padding": "16",
              "Child": {
                "Type": "Avalonia.Controls.TextBlock",
                "Properties": {
                  "Text": "User Profile",
                  "Foreground": { "$resource": "ForegroundBrush" },

                  "FontSize": 20,
                  "FontWeight": "Bold"
                }
              }
            }
          },

          {
            "Type": "Avalonia.Controls.StackPanel",
            "Properties": {
              "Avalonia.Controls.Grid.Row": 1,
              "Margin": "20",
              "Spacing": "15",
              "Children": [

                {
                  "Type": "Avalonia.Controls.Image",
                  "Properties": {
                    "Source": { "$asset": "/Assets/avalonia-logo.ico" },
                    "Width": 64,
                    "Height": 64,
                    "HorizontalAlignment": "Center",
                    "Margin": "0,0,0,10"
                  }
                },

                {
                  "Type": "Avalonia.Controls.StackPanel",
                  "Properties": {
                    "Spacing": 5,
                    "Children": [
                      {
                        "Type": "Avalonia.Controls.TextBlock",
                        "Properties": { "Text": "Username:" }
                      },
                      {
                        "Type": "Avalonia.Controls.TextBox",
                        "Properties": {
                          "Name": "UsernameInput",
                          "Watermark": "Enter username",
                          "Text": { "$binding": "UserName" }
                        }
                      }
                    ]
                  }
                },

                {
                  "Type": "Avalonia.Controls.StackPanel",
                  "Properties": {
                    "Spacing": 5,
                    "Children": [
                      {
                        "Type": "Avalonia.Controls.TextBlock",
                        "Properties": { "Text": "Status Message:" }
                      },
                      {
                        "Type": "Avalonia.Controls.TextBox",
                        "Properties": {
                          "Text": { "$binding": "Status" },
                          "AcceptsReturn": true,
                          "Height": 80
                        }
                      }
                    ]
                  }
                },

                {
                  "Type": "Avalonia.Controls.CheckBox",
                  "Properties": {
                    "Content": "Is Administrator",
                    "IsChecked": {
                      "$binding": "CanSave",
                      "Mode": "TwoWay"
                    }
                  }
                }
              ]
            }
          },

          {
            "Type": "Avalonia.Controls.StackPanel",
            "Properties": {
              "Avalonia.Controls.Grid.Row": 2,
              "Orientation": "Horizontal",
              "HorizontalAlignment": "Right",
              "Spacing": 10,
              "Margin": "15",
              "Children": [
                {
                  "Type": "Avalonia.Controls.Button",
                  "Properties": {
                    "Content": "Cancel"
                  }
                },
                {
                  "Type": "Avalonia.Controls.Button",
                  "Properties": {
                    "Name": "SaveButton",
                    "Content": "Save Changes",
                    "Classes": "accent h1",
                    "IsEnabled": {
                      "$binding": "CanSave",
                      "Mode": "TwoWay"
                    },
                    "Command": {
                      "$binding": "Save"
                    },
                    "HotKey": "Ctrl+S"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  }
}