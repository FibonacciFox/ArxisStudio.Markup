{
  "AssetType": "UserControl",
  "Properties": {
    "Width": 400,
    "Height": 250,

    "Content": {
      "Type": "Avalonia.Controls.Border",
      "Properties": {
        "Name": "GradientBorder",
        "BorderThickness": "5",
        "CornerRadius": "20",
        "Padding": "20",

        "BorderBrush": {
          "Type": "Avalonia.Media.LinearGradientBrush",
          "Properties": {
            "StartPoint": "0%,0%",
            "EndPoint": "100%,100%",
            "GradientStops": [
              {
                "Type": "Avalonia.Media.GradientStop",
                "Properties": {
                  "Color": "#FFFF0000",
                  "Offset": 0.0
                }
              },
              {
                "Type": "Avalonia.Media.GradientStop",
                "Properties": {
                  "Color": "#FF0000FF",
                  "Offset": 1.0
                }
              }
            ]
          }
        },

        "Background": {
          "Type": "Avalonia.Media.SolidColorBrush",
          "Properties": {
            "Color": "#10000000"
          }
        },

        "Child": {
          "Type": "Avalonia.Controls.TextBlock",
          "Properties": {
            "Text": "Gradient Test",
            "HorizontalAlignment": "Center",
            "VerticalAlignment": "Center",
            "FontSize": 24,
            "FontWeight": "Bold"
          }
        }
      }
    }
  }
}