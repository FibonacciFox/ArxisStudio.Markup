{
  "AssetType": "Window",
  "Properties": {
    "Width": 800,
    "Height": 600,
    "Title": "DockPanel Example", 

    "Content": {
      "Type": "Avalonia.Controls.DockPanel",
      "Properties": {
        "Name": "RootDock",
        "LastChildFill": true,

        "Children": [
          {
            "Type": "Avalonia.Controls.Border",
            "Properties": {
              "Name": "TopBorder",
              "Background": "#FFDDDDDD",
              "Height": 40,
              "Avalonia.Controls.DockPanel.Dock": "Top",

              "Child": {
                "Type": "Avalonia.Controls.TextBlock",
                "Properties": {
                  "Name": "HeaderText",
                  "Text": "Header Area",
                  "HorizontalAlignment": "Center",
                  "VerticalAlignment": "Center",
                  "Foreground": "#FF333333",
                  "FontSize": 18
                }
              }
            }
          },

          {
            "Type": "Avalonia.Controls.Border",
            "Properties": {
              "Name": "LeftBorder",
              "Background": "#FFEFEFEF",
              "Width": 180,
              "Avalonia.Controls.DockPanel.Dock": "Left",

              "Child": {
                "Type": "Avalonia.Controls.StackPanel",
                "Properties": {
                  "Name": "LeftPanel",
                  "Margin": "8",

                  "Children": [
                    {
                      "Type": "Avalonia.Controls.TextBlock",
                      "Properties": {
                        "Name": "MenuTitle",
                        "Text": "Menu",
                        "FontWeight": "Bold",
                        "Margin": "0,0,0,8"
                      }
                    },
                    {
                      "Type": "Avalonia.Controls.ListBox",
                      "Properties": {
                        "Name": "SideMenu",
                        "MinHeight": 200
                      }
                    }
                  ]
                }
              }
            }
          },

          {
            "Type": "Avalonia.Controls.Border",
            "Properties": {
              "Name": "RightBorder",
              "Background": "#FFF5F5F5",
              "Width": 200,
              "Avalonia.Controls.DockPanel.Dock": "Right",

              "Child": {
                "Type": "Avalonia.Controls.StackPanel",
                "Properties": {
                  "Name": "RightPanel",
                  "Margin": "8",

                  "Children": [
                    {
                      "Type": "Avalonia.Controls.Button",
                      "Properties": {
                        "Name": "ActionButton1",
                        "Content": "Action 1",
                        "Margin": "0,0,0,4"
                      }
                    },
                    {
                      "Type": "Avalonia.Controls.Button",
                      "Properties": {
                        "Name": "ActionButton2",
                        "Content": "Action 2",
                        "Margin": "0,4,0,0"
                      }
                    }
                  ]
                }
              }
            }
          },

          {
            "Type": "Avalonia.Controls.Border",
            "Properties": {
              "Name": "ContentBorder",
              "Background": "#FFFFFFFF",

              "Child": {
                "Type": "Avalonia.Controls.TextBlock",
                "Properties": {
                  "Name": "ContentText",
                  "Text": "Main content goes here",
                  "Margin": "16",
                  "TextWrapping": "Wrap"
                }
              }
            }
          }
        ]
      }
    }
  }
}