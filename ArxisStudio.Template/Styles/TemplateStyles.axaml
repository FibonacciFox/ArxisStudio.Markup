<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="TextBlock.eyebrow">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateAccentStrongBrush}" />
    </Style>

    <Style Selector="TextBlock.hero-title">
        <Setter Property="FontSize" Value="38" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateTitleBrush}" />
    </Style>

    <Style Selector="TextBlock.hero-copy">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateBodyBrush}" />
    </Style>

    <Style Selector="TextBlock.metric-value">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateAccentBrush}" />
    </Style>

    <Style Selector="TextBlock.metric-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateMutedBrush}" />
    </Style>

    <Style Selector="TextBlock.card-title">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateTitleBrush}" />
    </Style>

    <Style Selector="TextBlock.card-copy">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateBodyBrush}" />
    </Style>

    <Style Selector="Button.primary-action">
        <Setter Property="Background" Value="{DynamicResource TemplateAccentBrush}" />
        <Setter Property="Foreground" Value="#081018" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style Selector="Button.secondary-action">
        <Setter Property="Background" Value="{DynamicResource TemplatePanelAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TemplateBodyBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TemplateBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,10" />
    </Style>
</Styles>
