                                    "Text": "12"
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "metric-label",
                                    "HorizontalAlignment": "Left",
                                    "TextWrapping": "Wrap",
                                    "Text": ".arxui документов"
                                  }
                                }
                              ]
                            }
                          }
                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
                        }
                      },
                      {
                        "TypeName": "Avalonia.Controls.Border",
                        "Properties": {
                          "Width": 180,
                          "MinHeight": 96,
                          "Padding": "18",
                          "Background": {
                            "$resource": "TemplatePanelBrush"
                          },
                          "BorderBrush": {
                            "$resource": "TemplateBorderBrush"
                          },
                          "BorderThickness": "1",
                          "Child": {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "HorizontalAlignment": "Left",
                              "Spacing": 6,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "metric-value",
                                    "HorizontalAlignment": "Left",
                                    "Text": "4"
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "metric-label",
                                    "HorizontalAlignment": "Left",
                                    "TextWrapping": "Wrap",
                                    "Text": "подключённых .axaml файлов"
                                  }
                                }
                              ]
                            }
                          }
                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
                        }
                      },
                      {
                        "TypeName": "Avalonia.Controls.Border",
                        "Properties": {
                          "Width": 180,
                          "MinHeight": 96,
                          "Padding": "18",
                          "Background": {
                            "$resource": "TemplatePanelBrush"
                          },
                          "BorderBrush": {
                            "$resource": "TemplateBorderBrush"
                          },
                          "BorderThickness": "1",
                          "Child": {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "HorizontalAlignment": "Left",
                              "Spacing": 6,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "metric-value",
                                    "HorizontalAlignment": "Left",
