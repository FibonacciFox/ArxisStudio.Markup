                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
                        }
                      }
                    ]
                  }
                },
                {
                  "TypeName": "Avalonia.Controls.StackPanel",
                  "Properties": {
                    "Orientation": "Horizontal",
                    "HorizontalAlignment": "Stretch",
                    "Spacing": 18,
                    "Children": [
                      {
                        "TypeName": "Avalonia.Controls.Border",
                        "Properties": {
                          "Width": 280,
                          "MinHeight": 156,
                          "Padding": "18",
                          "Background": {
                            "$resource": "TemplatePanelAltBrush"
                          },
                          "BorderBrush": {
                            "$resource": "TemplateBorderBrush"
                          },
                          "BorderThickness": "1",
                          "Child": {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "HorizontalAlignment": "Left",
                              "Spacing": 8,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-title",
                                    "HorizontalAlignment": "Left",
                                    "Text": "Preview с учётом проекта"
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-copy",
                                    "HorizontalAlignment": "Left",
                                    "TextWrapping": "Wrap",
                                    "Text": "Редактор читает открытый проект, находит .arxui документы и применяет локальные стили и merged resources прямо во время preview."
                                  }
                                }
                              ]
                            }
                          }
                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
