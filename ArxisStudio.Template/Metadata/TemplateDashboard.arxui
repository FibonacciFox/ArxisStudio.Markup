                        "TypeName": "Avalonia.Controls.Border",
                        "Properties": {
                          "Width": 280,
                          "MinHeight": 156,
                          "Padding": "18",
                          "Background": {
                            "$resource": "TemplatePanelAltBrush"
                          },
                          "BorderBrush": {
                            "$resource": "TemplateBorderBrush"
                          },
                          "BorderThickness": "1",
                          "Child": {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "HorizontalAlignment": "Left",
                              "Spacing": 8,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-title",
                                    "HorizontalAlignment": "Left",
                                    "Text": "Безопасный design mode"
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-copy",
                                    "HorizontalAlignment": "Left",
                                    "TextWrapping": "Wrap",
                                    "Text": "Preview использует декларативную модель и ресурсы проекта без выполнения пользовательских обработчиков событий и application startup logic."
                                  }
                                }
                              ]
                            }
                          }
                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
                        }
                      },
