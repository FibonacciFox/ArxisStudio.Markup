                          "BorderThickness": "1",
                          "Child": {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "HorizontalAlignment": "Left",
                              "Spacing": 8,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-title",
                                    "HorizontalAlignment": "Left",
                                    "Text": "Расширяемая модель"
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.TextBlock",
                                  "Properties": {
                                    "Classes": "card-copy",
                                    "HorizontalAlignment": "Left",
                                    "TextWrapping": "Wrap",
                                    "Text": "Layout, ресурсы и стили остаются data-driven, благодаря чему конструктор остаётся универсальным и не завязан на жёстко заданный каталог виджетов."
                                  }
                                }
                              ]
                            }
                          }
                        },
                        "$design": {
                          "IgnorePreviewInput": true,
                          "AllowMove": true,
                          "AllowResize": true
                        }
                      }
                    ]
                  }
