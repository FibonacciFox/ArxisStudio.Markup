{
  "SchemaVersion": 1,
  "Kind": "Control",
  "Root": {
    "TypeName": "Avalonia.Controls.UserControl",
    "Properties": {
      "Background": "#0A0F14",
      "HorizontalAlignment": "Stretch",
      "VerticalAlignment": "Stretch",
      "Content": {
        "TypeName": "Avalonia.Controls.ScrollViewer",
        "Properties": {
          "HorizontalAlignment": "Stretch",
          "VerticalAlignment": "Stretch",
          "Padding": "28",
          "HorizontalScrollBarVisibility": "Disabled",
          "VerticalScrollBarVisibility": "Auto",
          "Content": {
            "TypeName": "Avalonia.Controls.StackPanel",
            "Properties": {
              "HorizontalAlignment": "Stretch",
              "VerticalAlignment": "Top",
              "MaxWidth": 920,
              "Spacing": 20,
              "Children": [
                {
                  "TypeName": "Avalonia.Controls.Border",
                  "Properties": {
                    "HorizontalAlignment": "Stretch",
                    "Background": {
                      "$resource": "LocalCardBrush"
                    },
                    "BorderBrush": {
                      "$resource": "TemplateBorderBrush"
                    },
                    "BorderThickness": "1",
                    "Padding": "24",
                    "Child": {
                      "TypeName": "Avalonia.Controls.StackPanel",
                      "Properties": {
                        "HorizontalAlignment": "Stretch",
                        "Spacing": 14,
                        "Children": [
                          {
                            "TypeName": "Avalonia.Controls.TextBlock",
                            "Properties": {
                              "Classes": "eyebrow",
                              "HorizontalAlignment": "Left",
                              "Text": "Шаблон ArxisStudio"
                            }
                          },
                          {
                            "TypeName": "Avalonia.Controls.TextBlock",
                            "Properties": {
                              "Classes": "hero-title",
                              "HorizontalAlignment": "Left",
                              "TextWrapping": "Wrap",
                              "MaxWidth": 720,
                              "Text": "Проектируйте более выразительные Avalonia-экраны из .arxui"
                            }
                          },
                          {
                            "TypeName": "Avalonia.Controls.TextBlock",
                            "Properties": {
                              "Classes": "hero-copy",
                              "HorizontalAlignment": "Left",
                              "TextWrapping": "Wrap",
                              "MaxWidth": 760,
                              "Text": "Этот шаблонный проект предназначен для открытия в ArxisStudio.Editor и для запуска как обычного приложения.\nОн демонстрирует загрузку проекта, внешние стили, merged resource dictionaries и более реалистичную dashboard-композицию."
                            }
                          },
                          {
                            "TypeName": "Avalonia.Controls.StackPanel",
                            "Properties": {
                              "Orientation": "Horizontal",
                              "HorizontalAlignment": "Left",
                              "Spacing": 12,
                              "Children": [
                                {
                                  "TypeName": "Avalonia.Controls.Button",
                                  "Properties": {
                                    "Classes": "primary-action",
                                    "MinWidth": 180,
                                    "HorizontalAlignment": "Left",
                                    "Content": "Открыть в дизайнере"
                                  },
                                  "$design": {
                                    "IgnorePreviewInput": true,
                                    "AllowMove": true,
                                    "AllowResize": false
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.Button",
                                  "Properties": {
                                    "Classes": "secondary-action",
                                    "MinWidth": 160,
                                    "HorizontalAlignment": "Left",
                                    "Content": "Просмотреть JSON"
                                  },
                                  "$design": {
                                    "IgnorePreviewInput": true,
                                    "AllowMove": true,
                                    "AllowResize": false
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.Button",
                                  "Properties": {
                                    "Classes": "secondary-action",
                                    "MinWidth": 170,
                                    "HorizontalAlignment": "Left",
                                    "Content": "Просмотреть preview"
                                  },
                                  "$design": {
                                    "IgnorePreviewInput": true,
                                    "AllowMove": true,
                                    "AllowResize": false
                                  }
                                },
                                {
                                  "TypeName": "Avalonia.Controls.Button",
                                  "Properties": {
                                    "Classes": "primary-action",
                                    "MinWidth": 170,
                                    "HorizontalAlignment": "Left",
                                    "Content": "Открыть"
                                  },
                                  "$design": {
                                    "IgnorePreviewInput": true,
                                    "AllowMove": true,
                                    "AllowResize": false
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
